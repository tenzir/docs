from {
  query: {
    hostname: "malware.example",
  },
  enrichments: [],
}
context::enrich "domain_indicator_enrichments",
  key=query.hostname,
  into=enrichments,
  mode="append",
  format="ocsf"
enrichment = enrichments.get(0)
select data=enrichment.data,
  name=enrichment.name,
  provider=enrichment.provider,
  has_type=enrichment.has("type"),
  value=enrichment.value
