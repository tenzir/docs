from {
  SHA1: "e8f4490420d0b0fc554d1296a8e9d5c35eb2b36e",
  enrichments: [],
}
context::enrich "sslbl",
  key=SHA1,
  into=enrichments,
  mode="append",
  format="ocsf"
enrichment = enrichments.get(0)
select fields=enrichment.keys().sort(),
  data=enrichment.data,
  provider=enrichment.provider,
  has_type=enrichment.has("type"),
  value=enrichment.value
