---
import { getCollection } from "astro:content";
import { pathWithBase } from "@utils/base";
import { resolvePageTitle } from "@utils/page-title";
import ReferenceIcon from "../icons/ReferenceIcon.astro";

// Build lookup map for page titles
const allDocs = await getCollection("docs");
const docsMap = new Map(allDocs.map((entry) => [entry.id, entry]));

const path = Astro.slots.has("default")
  ? (await Astro.slots.render("default")).trim()
  : "";
const href = pathWithBase(`/reference/${path}`);

const title = resolvePageTitle(docsMap, "reference", path);
---

<a href={href} class="semantic-link" data-tooltip="Reference"><ReferenceIcon class="inline-icon" />{title}</a>
