{
  "name": "tenzir-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run generate:excalidraw && astro dev",
    "start": "bun run dev",
    "build": "bun run generate:excalidraw && astro build",
    "preview": "bun install --silent --frozen-lockfile && astro preview",
    "astro": "astro",
    "generate": "bun run generate:changelog && bun run generate:excalidraw",
    "generate:changelog": "bun install --silent --frozen-lockfile && node scripts/sync-changelog.mjs",
    "generate:docs-bundle": "node scripts/generate-docs.mjs",
    "generate:excalidraw": "bun install --silent --frozen-lockfile && node scripts/generate-excalidraw-svgs.mjs",
    "generate:excalidraw:placeholders": "node scripts/generate-placeholder-svgs.mjs",
    "sync:openapi": "bash scripts/sync-openapi.sh",
    "lint": "lefthook run pre-push --all-files",
    "lint:files": "lefthook run pre-push --files-from-stdin",
    "lint:push": "lefthook run pre-push --all-files",
    "lint:markdown": "markdownlint '**/*.md' '**/*.mdx' --ignore node_modules --ignore .astro",
    "lint:markdown:files": "markdownlint --ignore node_modules --ignore .astro",
    "lint:markdown:fix": "markdownlint '**/*.md' '**/*.mdx' --ignore node_modules --ignore .astro --fix",
    "lint:markdown:fix:files": "markdownlint --ignore node_modules --ignore .astro --fix",
    "lint:biome": "biome check",
    "lint:biome:files": "biome check",
    "lint:biome:fix": "biome check --write",
    "lint:biome:fix:files": "biome check --write",
    "lint:prettier": "prettier --check '**/*.md'",
    "lint:prettier:files": "prettier --check",
    "lint:prettier:fix": "prettier --write '**/*.md'",
    "lint:prettier:fix:files": "prettier --write",
    "lefthook:install": "lefthook install",
    "lefthook:validate": "lefthook validate",
    "test:inline-partials": "bun run scripts/verify-inline-partials.ts",
    "test:sitemap-excerpts": "bun run scripts/verify-sitemap-excerpts.ts",
    "build:linkcheck": "CHECK_LINKS=true bun run build",
    "build:full": "bun run generate:changelog && CHECK_LINKS=true LLMS_TXT=true bun run build",
    "lint:fix": "lefthook run fix --all-files"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.39.2",
    "@excalidraw/utils": "0.1.3-test32",
    "@expressive-code/core": "0.42.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "ajv": "^8.20.0",
    "astro": "^6.3.3",
    "astro-breadcrumbs": "^3.4.0",
    "feed": "^5.2.1",
    "github-slugger": "^2.0.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-has-property": "^3.0.0",
    "hast-util-select": "^6.0.4",
    "is-absolute-url": "^5.0.0",
    "jsdom": "^29.1.1",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "micromatch": "^4.0.8",
    "rehype-external-links": "^3.0.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-mdx": "^3.1.1",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "starlight-links-validator": "^0.24.0",
    "starlight-openapi": "^0.25.2",
    "tree-sitter-tql": "^1.0.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@peculiar/webcrypto": "^1.7.1",
    "lefthook": "^2.1.6",
    "markdownlint-cli": "^0.48.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3"
  }
}
